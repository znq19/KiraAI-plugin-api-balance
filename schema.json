{
  "section_deepseek": {
    "type": "section",
    "name": "DeepSeek",
    "collapsed": true,
    "fields": {
      "deepseek_base_url": {
        "type": "string",
        "name": "API 基础网址",
        "default": "https://api.deepseek.com",
        "hint": "DeepSeek API 的基础 URL"
      },
      "deepseek_api_key": {
        "type": "sensitive",
        "name": "API Key",
        "default": "",
        "hint": "填写 DeepSeek API Key"
      }
    }
  },
  "section_siliconflow": {
    "type": "section",
    "name": "SiliconFlow",
    "collapsed": true,
    "fields": {
      "siliconflow_base_url": {
        "type": "string",
        "name": "API 基础网址",
        "default": "https://api.siliconflow.cn",
        "hint": "SiliconFlow API 的基础 URL"
      },
      "siliconflow_api_key": {
        "type": "sensitive",
        "name": "API Key",
        "default": "",
        "hint": "填写 SiliconFlow API Key"
      }
    }
  },
  "section_moonshot": {
    "type": "section",
    "name": "月之暗面 (Kimi)",
    "collapsed": true,
    "fields": {
      "moonshot_base_url": {
        "type": "string",
        "name": "API 基础网址",
        "default": "https://api.moonshot.cn/v1",
        "hint": "月之暗面 API 的基础 URL"
      },
      "moonshot_api_key": {
        "type": "sensitive",
        "name": "API Key",
        "default": "",
        "hint": "填写 Kimi API Key，从 platform.moonshot.cn 获取"
      }
    }
  },
  "section_newapi_simple": {
    "type": "section",
    "name": "New API 站点（简易文本格式）",
    "collapsed": true,
    "fields": {
      "newapi_sites_simple": {
        "type": "list",
        "name": "简易站点列表（每行一个，分号分隔）",
        "default": [],
        "hint": "每行格式：名称;base_url;系统访问令牌;纯数字用户ID;换算比例（可选，默认500000）\n示例：我的站点1;https://api.example.com;sk-xxxxxxxx;123456;500000"
      }
    }
  },
  "section_newapi": {
    "type": "section",
    "name": "New API 站点（JSON 格式）",
    "collapsed": true,
    "fields": {
      "newapi_sites": {
        "type": "json",
        "name": "JSON 格式站点列表",
        "default": [
          {
            "name": "示例站1",
            "base_url": "https://api.example.com",
            "api_key": "sk-xxxxxxxx",
            "api_user": "123456",
            "quota_conversion": 500000
          },
          {
            "name": "示例站2",
            "base_url": "https://api2.example.com",
            "api_key": "sk-yyyyyyyy",
            "api_user": "789012",
            "quota_conversion": 500000
          }
        ],
        "hint": "填写多个站点的配置，格式：[{\"name\": \"站点名称\", \"base_url\": \"https://xxx.com\", \"api_key\": \"系统访问令牌\", \"api_user\": \"纯数字用户ID\", \"quota_conversion\": 500000}, ...]。quota_conversion 表示 quota ÷ 该值 = 元，默认 500000。"
      }
    }
  },
  "enable_keyword_trigger": {
    "type": "switch",
    "name": "启用关键词触发",
    "default": true
  }
}
